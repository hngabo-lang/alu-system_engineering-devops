#!/usr/bin/env bash
# Installs nginx, serves a page containing "Holberton School", and configures
# /redirect_me to return a 301 Moved Permanently redirect.

apt-get update -y
apt-get install -y nginx

echo "Holberton School" > /var/www/html/index.html

# Write the full default server block (avoids sed backslash-continuation,
# which shellcheck (SC1004) flags as unsafe inside single quotes).
cat > /etc/nginx/sites-available/default << 'NGINX_EOF'
server {
	listen 80 default_server;
	listen [::]:80 default_server;

	root /var/www/html;
	index index.html index.htm index.nginx-debian.html;

	server_name _;

	location /redirect_me {
		return 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;
	}

	location / {
		try_files $uri $uri/ =404;
	}
}
NGINX_EOF

# Start nginx without systemctl. Some Docker-based grading environments
# ship a policy-rc.d that silently blocks `service`/`invoke-rc.d` calls
# (including nginx's own postinst auto-start), so fall back to the binary
# directly if it isn't actually running afterward.
service nginx start
if pgrep -x nginx > /dev/null 2>&1; then
    nginx -s reload
else
    nginx
fi
